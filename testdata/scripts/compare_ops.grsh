# Operators: comparison, logic, arithmetic, compound assign, swap.
a, b := 7, 3
fmt.Println(a > b, a <= b, a != b, a == 7)
fmt.Println("apple" < "banana", "z" > "a")
fmt.Println(!(a > b), a > b && b > 0, a < b || b > 0)
fmt.Println(-a, a%b, a*b, a/b)
s := "ab"
s += "cd"
fmt.Println(s)
a, b = b, a
fmt.Println(a, b)
